# Optional — override default endpoints (e.g. for V2 staging)
# CLOB_HOST=https://clob.polymarket.com
# GAMMA_HOST=https://gamma-api.polymarket.com
# DATA_HOST=https://data-api.polymarket.com

# Local SQLite cache location (default: ./data/cache.db)
# CACHE_DB=./data/cache.db

# Default fee rate to assume when market metadata is missing (V2 default 2%)
# DEFAULT_FEE_RATE=0.02
